# broken.lmp — deliberately broken LAMMPS script for testing lmpcheck
# Contains 5 embedded static bugs annotated with # BUG N:

clear
variable Run         equal 1
variable dt          equal 3
variable T           equal 620
variable LJ_Cutoff   equal 9.625

# Time-step variables
variable 5ps   equal floor(5/(${dt}/1000))
variable 1ns   equal floor(1000/(${dt}/1000))
variable 2ns   equal floor(2000/(${dt}/1000))

# BUG 2: division without floor(), bad_steps is non-integer; used in run below
variable bad_steps equal 5000/(${dt}/1000)

log L.1.log  # BUG 3: hardcoded run number; other outputs use ${Run}

units real
boundary p p p
atom_style molecular
bond_style harmonic
angle_style harmonic

pair_style lj/long/coul/long long off ${LJ_Cutoff}
special_bonds lj 0.0 0.0 0.0
pair_modify mix arithmetic

# BUG 4: data file does not exist
read_data nonexistent.dat

# broken.dat exists and has 2 atom types — used for atom-type check context
read_data broken.dat

pair_coeff 1 1 0.091411 3.95 ${LJ_Cutoff}
pair_coeff 2 2 0.19476  3.75 ${LJ_Cutoff}
# BUG 5: atom type 3 does not exist in broken.dat (only 2 atom types declared)
pair_coeff 3 3 0.15 3.80 ${LJ_Cutoff}

kspace_style pppm/disp 0

velocity all create ${T} 12345 mom yes rot yes dist gaussian

# BUG 1: ${nstps} is undefined — typo, likely meant ${5ps} or similar
run ${nstps}

# BUG 2 trigger: bad_steps used as step count without floor()
run ${bad_steps}

dump EQDump all custom ${1ns} EQ.${Run}.lammpstrj id mol x y z
dump_modify EQDump element CH2 CH3

fix NVT all nvt temp ${T} ${T} 100
run ${2ns}
unfix NVT
undump EQDump

write_data W.${Run}.data
write_restart W.1.NVE  # BUG 3: hardcoded — should be W.${Run}.NVE
